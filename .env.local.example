# ─── NEON DATABASE ────────────────────────────────────────────────────────────
# Get this from: neon.tech → your project → Connection string → .env
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generate a secret: run `openssl rand -base64 32` in your terminal
AUTH_SECRET=your_random_secret_here

# Your app's URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── GOOGLE OAUTH (optional — for "Continue with Google") ────────────────────
# Get from: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── RESEND EMAIL (for deadline reminders) ───────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ─── CRON SECURITY ───────────────────────────────────────────────────────────
CRON_SECRET=your_cron_secret_here
